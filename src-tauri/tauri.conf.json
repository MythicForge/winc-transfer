{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WINC",
  "version": "0.4.2",
  "identifier": "com.winc.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "WINC — Data Crossing",
        "width": 1060,
        "height": 780,
        "minWidth": 720,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
